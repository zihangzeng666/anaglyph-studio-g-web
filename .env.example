# Anaglyph Studio (G) marketing site — public env (static export)
# Copy to .env.local for local overrides. Never commit real secrets here.

# External release zips (HTTPS only). Never point at public/downloads/*.zip
NEXT_PUBLIC_DL_RUNTIME_URL=https://example.com/releases/Anaglyph_Studio_G_2026-07-18.zip
NEXT_PUBLIC_DL_SOURCE_URL=https://example.com/releases/Anaglyph_Studio_G_Source_2026-07-18.zip

# SHA-256 of hosted artifacts (hex). Keep PLACEHOLDER until measured.
# NEXT_PUBLIC_DL_RUNTIME_SHA256=
# NEXT_PUBLIC_DL_SOURCE_SHA256=

# Hold-to-explore (default play-only / off until media QA)
# NEXT_PUBLIC_ENABLE_HOLD_EXPLORE=0
# NEXT_PUBLIC_HOLD_MODE=play-only

# Demo form (PR9)
# NEXT_PUBLIC_DEMO_MAILTO=demo@example.com
# NEXT_PUBLIC_FORMSPREE_ID=

# Analytics (PR9) — no-op unless vendor id set
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
